<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.example.board.dao.BoardMapper">

    <!-- 재사용할 SQL 블록: 공통 컬럼 -->
    <sql id="boardColumns">
        BOARD_ID,
        TITLE,
        CONTENT,
        AUTHOR,
        CREATED_DATE,
        UPDATED_DATE,
        VIEW_COUNT
    </sql>

    <!-- 재사용할 SQL 블록: WHERE 조건 (향후 검색 기능 확장용) -->
    <sql id="searchCondition">
        <where>
            1 = 1
            <if test="searchType != null and searchKeyword != null">
                <choose>
                    <when test="searchType == 'title'">
                        AND TITLE LIKE CONCAT('%', #{searchKeyword}, '%')
                    </when>
                    <when test="searchType == 'content'">
                        AND CONTENT LIKE CONCAT('%', #{searchKeyword}, '%')
                    </when>
                    <when test="searchType == 'author'">
                        AND AUTHOR LIKE CONCAT('%', #{searchKeyword}, '%')
                    </when>
                </choose>
            </if>
        </where>
    </sql>

    <!-- 전체 게시물 개수 조회 -->
    <select id="getTotalCount" resultType="int">
        SELECT COUNT(*) FROM BOARD
    </select>

    <!-- 게시물 목록 조회 (페이지네이션) -->
    <select id="getList" resultType="Board">
        SELECT
            <include refid="boardColumns" />
        FROM BOARD
        ORDER BY CREATED_DATE DESC
        LIMIT #{pageSize} OFFSET #{offset}
    </select>

    <!-- 게시물 상세 조회 -->
    <select id="getById" resultType="Board">
        SELECT
            <include refid="boardColumns" />
        FROM BOARD
        WHERE BOARD_ID = #{boardId}
    </select>

    <!-- 게시물 생성 -->
    <insert id="insert" useGeneratedKeys="true" keyProperty="boardId">
        INSERT INTO BOARD (TITLE, CONTENT, AUTHOR, CREATED_DATE, UPDATED_DATE, VIEW_COUNT)
        VALUES (#{title}, #{content}, #{author}, CURRENT_TIMESTAMP, CURRENT_TIMESTAMP, 0)
    </insert>

    <!-- 게시물 수정 -->
    <update id="update">
        UPDATE BOARD
        SET TITLE = #{title},
            CONTENT = #{content},
            AUTHOR = #{author},
            UPDATED_DATE = CURRENT_TIMESTAMP
        WHERE BOARD_ID = #{boardId}
    </update>

    <!-- 게시물 삭제 -->
    <delete id="delete">
        DELETE FROM BOARD
        WHERE BOARD_ID = #{boardId}
    </delete>

    <!-- 조회수 증가 -->
    <update id="increaseViewCount">
        UPDATE BOARD
        SET VIEW_COUNT = VIEW_COUNT + 1
        WHERE BOARD_ID = #{boardId}
    </update>

</mapper>
